{
  "name": "@qefro-ai/widget",
  "version": "1.1.7",
  "description": "Embeddable AI chat widget for Qefro customer support",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/widget.umd.cjs",
  "module": "./dist/widget.js",
  "unpkg": "./dist/widget.iife.js",
  "jsdelivr": "./dist/widget.iife.js",
  "exports": {
    ".": {
      "import": "./dist/widget.js",
      "require": "./dist/widget.umd.cjs"
    },
    "./widget.iife.js": "./dist/widget.iife.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qefro-ai/ai-customer-support-widget.git"
  },
  "homepage": "https://qefro.com",
  "license": "UNLICENSED",
  "keywords": [
    "qefro",
    "chat",
    "widget",
    "ai",
    "customer-support",
    "rag"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/postbuild.mjs",
    "prepublishOnly": "npm run build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@huggingface/transformers": "4.2.0",
    "dompurify": "^3.4.9"
  }
}
